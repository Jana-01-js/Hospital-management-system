
# .gitignore

```gitignore
# Dependencies
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database
*.sql
*.sqlite
*.db

# Build Files
dist/
build/

# Coverage
coverage/

# OS Files
.DS_Store
Thumbs.db

# IDE Files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Temporary Files
tmp/
temp/
.cache/

# Runtime Data
pids
*.pid
*.seed
*.pid.lock

# Package Lock Files (optional)
package-lock.json
yarn.lock
